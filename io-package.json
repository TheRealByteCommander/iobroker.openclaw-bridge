{
  "common": {
    "name": "openclaw-bridge",
    "version": "0.3.0",
    "news": {
      "0.3.0": {
        "en": "Add conversational intent handling, context events, critical-action confirmation and PV surplus trigger",
        "de": "Conversational Intent-Handling, Kontext-Events, Bestätigung für kritische Aktionen und PV-Überschuss-Trigger ergänzt"
      },
      "0.2.0": {
        "en": "Add request correlation, structured errors, action whitelist, ACL checks, timeout handling, audit metrics and batch getStates",
        "de": "Request-Korrelation, strukturierte Fehler, Action-Whitelist, ACL-Prüfungen, Timeout-Handling, Audit-Metriken und batch getStates ergänzt"
      },
      "0.1.0": {
        "en": "Initial MVP bridge for ioBroker state read/write from OpenClaw workflows",
        "de": "Initiales MVP-Bridge für ioBroker State-Read/Write aus OpenClaw-Workflows"
      }
    },
    "titleLang": {
      "en": "OpenClaw Bridge",
      "de": "OpenClaw Bridge"
    },
    "desc": {
      "en": "Bridge adapter exposing command and result states for external assistants",
      "de": "Bridge-Adapter mit Command- und Result-States für externe Assistenten"
    },
    "authors": [
      "Byte Commander"
    ],
    "keywords": [
      "openclaw",
      "bridge",
      "assistant"
    ],
    "license": "MIT",
    "platform": "Javascript/Node.js",
    "mode": "daemon",
    "type": "misc-data",
    "icon": "openclaw-bridge.png",
    "enabled": true,
    "extIcon": "",
    "readme": "https://github.com/TheRealByteCommander/ioBroker/blob/master/README.md",
    "loglevel": "info",
    "messagebox": true,
    "connectionType": "local",
    "dataSource": "push",
    "compact": true,
    "adminUI": {
      "config": "none"
    }
  },
  "native": {
    "allowedPrefixes": "javascript.0,0_userdata.0",
    "allowedActions": "getState,setState,listStates,getStates,ping,handleIntent,executePlan,emitContextEvent,handlePvSurplus",
    "commandTimeoutMs": 5000,
    "setStateAckAllowed": true,
    "criticalStatePrefixes": "system.,admin.0",
    "requireConfirmationActions": "executePlan",
    "comfortTemperatureStateId": "0_userdata.0.hvac.livingRoom.targetTemperature",
    "comfortTempStep": 1,
    "pvSurplusMinWatts": 1500,
    "pvSurplusLoadStateId": "0_userdata.0.energy.pvSurplusMode"
  },
  "objects": [
    {
      "_id": "control.command",
      "type": "state",
      "common": {
        "name": "JSON command",
        "type": "string",
        "role": "json",
        "read": true,
        "write": true,
        "def": ""
      },
      "native": {}
    },
    {
      "_id": "control.lastResult",
      "type": "state",
      "common": {
        "name": "Last command result",
        "type": "string",
        "role": "json",
        "read": true,
        "write": false,
        "def": ""
      },
      "native": {}
    },
    {
      "_id": "responses",
      "type": "channel",
      "common": {
        "name": "Per-request responses"
      },
      "native": {}
    },
    {
      "_id": "intents.lastPlan",
      "type": "state",
      "common": {
        "name": "Last generated intent plan",
        "type": "string",
        "role": "json",
        "read": true,
        "write": false,
        "def": ""
      },
      "native": {}
    },
    {
